# Optional service-level compatibility fallback. Normal chain runs should prefer
# the user selected key stored through the backend API config flow.
AIMV_DASHSCOPE_API_KEY=
AIMV_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
AIMV_DASHSCOPE_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AIMV_DASHSCOPE_LLM_MODEL=qwen-plus
AIMV_DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
AIMV_DASHSCOPE_EMBEDDING_DIMENSIONS=1024
AIMV_DASHSCOPE_RERANK_MODEL=qwen3-rerank
AIMV_DASHSCOPE_RERANK_TOP_N=2
AIMV_DASHSCOPE_IMAGE_MODEL=wan2.6-t2i
AIMV_DASHSCOPE_IMAGE_SIZE=720*1280
AIMV_DASHSCOPE_VIDEO_MODEL=wan2.7-t2v
AIMV_DASHSCOPE_VIDEO_RESOLUTION=720P
AIMV_DASHSCOPE_VIDEO_RATIO=9:16
AIMV_DASHSCOPE_VIDEO_DURATION_SECONDS=10
# Video async task polling. Defaults now poll (60 attempts x 10s) so a real video
# task can complete; 0 attempts means "submit only, never poll" (fixture/testing).
AIMV_DASHSCOPE_VIDEO_POLL_ATTEMPTS=60
AIMV_DASHSCOPE_VIDEO_POLL_INTERVAL=10s
# Only set true if the selected video model natively outputs audible human voice.
# The default false makes V30 honestly block (WAITING_CAPABILITY) instead of
# claiming a capability the model does not have.
AIMV_DASHSCOPE_VIDEO_NATIVE_VOICE=false

# Optional generic HTTP provider adapter for non-fixture, non-DashScope providers.
AIMV_PROVIDER_ADAPTER_BASE_URL=

# API key encryption. Provide a stable Base64-encoded 32-byte AES key in
# production; otherwise a key file is generated and reused so stored credentials
# survive restarts. Do NOT commit either value.
# AIMV_CREDENTIAL_AES_KEY=
# AIMV_CREDENTIAL_KEY_FILE=~/.aimv/credential.key

# Chain execution. false = async background execution (frontend polls progress);
# true = run the whole chain synchronously inside the request (used by tests).
AIMV_CHAIN_RUN_SYNC=false

# Comma-separated CORS origin patterns allowed to call the API / static assets.
AIMV_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*

# PostgreSQL profile.
AIMV_POSTGRES_URL=jdbc:postgresql://127.0.0.1:5432/aimv
AIMV_POSTGRES_USERNAME=aimv
AIMV_POSTGRES_PASSWORD=aimv
